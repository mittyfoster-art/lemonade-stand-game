# Supabase credentials (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Auth mock toggle: set to "true" to use mock auth for development.
# Defaults to false (real Supabase OTP auth) when not set.
VITE_AUTH_MOCK=true

# Sentry error tracking (optional, production only)
# Get your DSN from https://sentry.io/ after creating a project.
# VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id
